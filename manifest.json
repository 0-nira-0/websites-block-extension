{
  "manifest_version": 3,
  "name": "just focus",
  "version": "0.1.0",
  "description": "block distractions, ship work, stay hard.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "just focus"
  },
  "background": {
    "service_worker": "src/background/sw.ts",
    "type": "module"
  },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "alarms",
    "tabs",
    "activeTab",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": [
        "src/redirect/index.html",
        "src/complete/index.html"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
